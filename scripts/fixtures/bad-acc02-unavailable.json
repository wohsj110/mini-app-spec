{
  "description": "SRC-fig observed as unavailable in the batch (figma 401), acceptance has no matching sourceWaiver",
  "base": "valid-typical.json",
  "expect": [
    "ACC-02"
  ],
  "ops": [
    {
      "op": "replace",
      "path": "/ledger/sourceObservations/1/outcome",
      "value": "unavailable"
    },
    {
      "op": "replace",
      "path": "/ledger/sourceObservations/1/observedHash",
      "value": null
    },
    {
      "op": "add",
      "path": "/ledger/sourceObservations/1/unavailableReason",
      "value": "figma API 401"
    }
  ]
}
